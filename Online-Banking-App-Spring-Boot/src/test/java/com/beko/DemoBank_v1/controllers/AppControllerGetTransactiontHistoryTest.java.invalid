    @Test
    @Tag("integration")
    public void testHandleConcurrentSessionsWithoutConflicts() throws Exception {
        User userA = mock(User.class);
        User userB = mock(User.class);
        String userIdStrA = "900";
        String userIdStrB = "901";
        int userIdA = 900;
        int userIdB = 901;
        List<TransactionHistory> txA = Arrays.asList(mock(TransactionHistory.class), mock(TransactionHistory.class));
        List<TransactionHistory> txB = Arrays.asList(mock(TransactionHistory.class));
        HttpSession sessionA = mock(HttpSession.class);
        HttpSession sessionB = mock(HttpSession.class);
        when(sessionA.getAttribute("user")).thenReturn(userA);
        when(userA.getUser_id()).thenReturn(userIdStrA);
        when(transactHistoryRepository.getTransactionRecordsById(userIdA)).thenReturn(txA);
        when(sessionB.getAttribute("user")).thenReturn(userB);
        when(userB.getUser_id()).thenReturn(userIdStrB);
        when(transactHistoryRepository.getTransactionRecordsById(userIdB)).thenReturn(txB);
        // Simulate concurrent requests by running both in parallel threads
        final List<ResponseEntity<?>> results = new ArrayList<>();
        Thread threadA = new Thread(() -> results.add(appController.getTransactiontHistory(sessionA)));
        Thread threadB = new Thread(() -> results.add(appController.getTransactiontHistory(sessionB)));
        threadA.start();
        threadB.start();
        threadA.join();
        threadB.join();
        assertEquals(2, results.size());
        // Order can vary, so search by user and expected txList size
        boolean foundA = results.stream().anyMatch(resp -> ((List<?>)((Map<?,?>)resp.getBody()).get("transaction_history")).size() == 2);
        boolean foundB = results.stream().anyMatch(resp -> ((List<?>)((Map<?,?>)resp.getBody()).get("transaction_history")).size() == 1);
        assertTrue(foundA);
        assertTrue(foundB);
    }
