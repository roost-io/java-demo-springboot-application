        when(transactHistoryRepository.getTransactionRecordsById(userId)).thenReturn(mockedList);
        ResponseEntity<?> response = appController.getTransactiontHistory(session);
        assertEquals(HttpStatus.OK, response.getStatusCode());
        assertTrue(((Map<?,?>)response.getBody()).containsKey("transaction_history"));
        assertEquals(mockedList, ((Map<?,?>)response.getBody()).get("transaction_history"));
    }
