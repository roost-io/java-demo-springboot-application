    @Test
    @Tag("invalid")
    public void negativeWithdrawalAmountIncreasesBalanceAndReturnsOk() {
        int userId = 909;
        int accountId = 44;
        double currentBalance = 500.00;
        double withdrawal = -100.00;
        double expectedNewBalance = currentBalance - withdrawal;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        HashMap<String, Object> accounts = new HashMap<>();
        when(accountRepository.getUserAccountsById(userId)).thenReturn(accounts);
        Map<String, String> requestMap = buildRequest("-100.00", "44");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) response.getStatusCode());
        verify(accountRepository).changeAccountsBalanceById((double) expectedNewBalance, (int) accountId);
        verify(transactRepository).logTransaction(eq((int) accountId), eq((String) "Withdrawal"), eq((double) withdrawal), eq((String) "online"), eq((String) "success"), eq((String) "Withdrawal Transaction Successfull"), any(LocalDateTime.class));
    }
    @Test
    @Tag("boundary")
    public void fractionalWithdrawalWithPrecisionSucceeds() {
        int userId = 111;
