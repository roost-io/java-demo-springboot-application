    @Test
    @Tag("integration")
    public void getUserAccountsByIdExceptionPropagatesAfterSuccessPath() {
        int userId = 888;
        int accountId = 55;
        double currentBalance = 400.0;
        double withdrawal = 40.0;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        doThrow(new RuntimeException("accounts fetch failed")).when(accountRepository).getUserAccountsById(userId);
        Map<String, String> requestMap = buildRequest("40.00", "55");
        assertThrows(RuntimeException.class, () -> controller.transfer(requestMap, session));
        verify(accountRepository).changeAccountsBalanceById(eq((double) (currentBalance - withdrawal)), eq((int) accountId));
        verify(transactRepository).logTransaction(eq((int) accountId), eq((String) "Withdrawal"), eq((double) withdrawal), eq((String) "online"), eq((String) "success"), eq((String) "Withdrawal Transaction Successfull"), any(LocalDateTime.class));
    }
    @Test
    @Tag("valid")
    public void transactionTypeCaseSensitivityDiffersBetweenFailureAndSuccess() {
        int userId = 999;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        // First run: insufficient funds
        int accountIdFail = 60;
        when(accountRepository.getAccountBalance(userId, accountIdFail)).thenReturn(10.0);
        Map<String, String> requestFail = buildRequest("20.00", String.valueOf(accountIdFail));
        ResponseEntity responseFail = controller.transfer(requestFail, session);
        assertEquals((HttpStatus) HttpStatus.BAD_REQUEST, (HttpStatus) responseFail.getStatusCode());
        // Second run: sufficient funds
        int accountIdSuccess = 61;
        when(accountRepository.getAccountBalance(userId, accountIdSuccess)).thenReturn(100.0);
        when(accountRepository.getUserAccountsById(userId)).thenReturn(new HashMap<String, Object>());
        Map<String, String> requestSuccess = buildRequest("20.00", String.valueOf(accountIdSuccess));
        ResponseEntity responseSuccess = controller.transfer(requestSuccess, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) responseSuccess.getStatusCode());
        verify(transactRepository).logTransaction(eq((int) accountIdFail), eq((String) "withdrawal"), eq((double) 20.00), eq((String) "online"), eq((String) "failed"), eq((String) "Insufficient funds."), any(LocalDateTime.class));
        verify(transactRepository).logTransaction(eq((int) accountIdSuccess), eq((String) "Withdrawal"), eq((double) 20.00), eq((String) "online"), eq((String) "success"), eq((String) "Withdrawal Transaction Successfull"), any(LocalDateTime.class));
    }
