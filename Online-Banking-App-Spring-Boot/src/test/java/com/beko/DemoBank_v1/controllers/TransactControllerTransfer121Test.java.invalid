    @Test
    @Tag("valid")
    public void successResponseContainsAccountsFromRepository() {
        int userId = 1234;
        int accountId = 12;
        double currentBalance = 500.0;
        double withdrawal = 10.0;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        HashMap<String, Object> accounts = new HashMap<>();
        accounts.put("owned", true);
        when(accountRepository.getUserAccountsById(userId)).thenReturn(accounts);
        Map<String, String> requestMap = buildRequest("10.00", "12");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) response.getStatusCode());
        Map<?, ?> body = (Map<?, ?>) response.getBody();
        assertSame((Object) accounts, (Object) body.get("accounts"));
    }
    @Test
    @Tag("integration")
    public void callOrderOnSuccessBalanceThenLogThenFetchAccounts() {
        int userId = 1414;
        int accountId = 21;
        double currentBalance = 200.0;
        double withdrawal = 20.0;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        when(accountRepository.getUserAccountsById(userId)).thenReturn(new HashMap<String, Object>());
        Map<String, String> requestMap = buildRequest("20.00", "21");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) response.getStatusCode());
        InOrder inOrder = inOrder(accountRepository, transactRepository);
        inOrder.verify(accountRepository).getAccountBalance((int) userId, (int) accountId);
        inOrder.verify(accountRepository).changeAccountsBalanceById(eq((double) (currentBalance - withdrawal)), eq((int) accountId));
        inOrder.verify(transactRepository).logTransaction(eq((int) accountId), eq((String) "Withdrawal"), eq((double) withdrawal), eq((String) "online"), eq((String) "success"), eq((String) "Withdrawal Transaction Successfull"), any(LocalDateTime.class));
        inOrder.verify(accountRepository).getUserAccountsById((int) userId);
    }
