import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;
import org.junit.jupiter.api.*;
import com.beko.DemoBank_v1.models.PaymentRequest;
import com.beko.DemoBank_v1.models.TransferRequest;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import javax.servlet.http.HttpServletRequest;

@ExtendWith(MockitoExtension.class)
public class TransactControllerTransfer121Test {
    @Mock
    private AccountRepository accountRepository;
    @Mock
    private PaymentRepository paymentRepository;
    @Mock
    private TransactRepository transactRepository;
    @Mock
    private HttpSession session;
    @InjectMocks
    private TransactController controller;
    private static final double DELTA = 1e-6; // TODO: adjust tolerance if using different double precision
    private static final long TIME_TOLERANCE_SECONDS = 600L; // TODO: adjust acceptable time skew if test environments require
    private Map<String, String> buildRequest(String withdrawalAmount, String accountId) {
        Map<String, String> request = new HashMap<>();
        request.put("withdrawal_amount", withdrawalAmount);
        request.put("account_id", accountId);
        return request;
    }
    private User mockUserWithId(String userId) {
        User mockUser = mock(User.class);
        when(mockUser.getUser_id()).thenReturn(userId);
        return mockUser;
    }
    private void assertDateWithinTolerance(LocalDateTime captured) {
        assertNotNull(captured);
        LocalDateTime now = LocalDateTime.now();
        assertTrue(captured.isBefore(now.plusSeconds(TIME_TOLERANCE_SECONDS)));
    }
    @BeforeEach
    void init() {
        // No-op setup. Field initialization handled by @InjectMocks and @Mock
    }
    @Test
    @Tag("valid")
    public void successfulWithdrawalReducesBalanceAndReturnsOk() {
        int userId = 101;
        int accountId = 10;
        double currentBalance = 300.00;
        double withdrawal = 100.00;
        double expectedNewBalance = currentBalance - withdrawal;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        HashMap<String, Object> accounts = new HashMap<>();
        accounts.put("list", "dummy"); // TODO: replace with real accounts structure if available
        when(accountRepository.getUserAccountsById(userId)).thenReturn(accounts);
        Map<String, String> requestMap = buildRequest("100.00", "10");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) response.getStatusCode());
        assertTrue(response.getBody() instanceof Map);
        Map<?, ?> body = (Map<?, ?>) response.getBody();
        assertEquals((String) "Withdrawal Successfull!", (String) body.get("message"));
        assertSame((Object) accounts, (Object) body.get("accounts"));
        verify(accountRepository, times(1)).getAccountBalance((int) userId, (int) accountId);
        verify(accountRepository, times(1)).changeAccountsBalanceById((double) expectedNewBalance, (int) accountId);
        ArgumentCaptor<Integer> accIdCaptor = ArgumentCaptor.forClass(Integer.class);
        ArgumentCaptor<String> typeCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<Double> amountCaptor = ArgumentCaptor.forClass(Double.class);
        ArgumentCaptor<String> channelCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<String> statusCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<String> messageCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<LocalDateTime> timeCaptor = ArgumentCaptor.forClass(LocalDateTime.class);
        verify(transactRepository, times(1)).logTransaction(
                accIdCaptor.capture(),
                typeCaptor.capture(),
                amountCaptor.capture(),
                channelCaptor.capture(),
                statusCaptor.capture(),
                messageCaptor.capture(),
                timeCaptor.capture()
        );
        assertEquals((int) accountId, (int) accIdCaptor.getValue());
        assertEquals((String) "Withdrawal", (String) typeCaptor.getValue());
        assertEquals((double) withdrawal, (double) amountCaptor.getValue(), (double) DELTA);
        assertEquals((String) "online", (String) channelCaptor.getValue());
        assertEquals((String) "success", (String) statusCaptor.getValue());
        assertEquals((String) "Withdrawal Transaction Successfull", (String) messageCaptor.getValue());
        assertDateWithinTolerance(timeCaptor.getValue());
    }
    @Test
    @Tag("boundary")
    public void withdrawalEqualToBalanceSucceedsAndResultsInZeroBalance() {
        int userId = 202;
        int accountId = 55;
        double currentBalance = 100.00;
        double withdrawal = 100.00;
        double expectedNewBalance = 0.0;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        HashMap<String, Object> accounts = new HashMap<>();
        when(accountRepository.getUserAccountsById(userId)).thenReturn(accounts);
        Map<String, String> requestMap = buildRequest("100.00", "55");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.OK, (HttpStatus) response.getStatusCode());
        Map<?, ?> body = (Map<?, ?>) response.getBody();
        assertEquals((String) "Withdrawal Successfull!", (String) body.get("message"));
        verify(accountRepository, times(1)).changeAccountsBalanceById((double) expectedNewBalance, (int) accountId);
        ArgumentCaptor<String> typeCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<String> statusCaptor = ArgumentCaptor.forClass(String.class);
        verify(transactRepository).logTransaction(eq((int) accountId), typeCaptor.capture(), eq((double) withdrawal), eq((String) "online"), statusCaptor.capture(), eq((String) "Withdrawal Transaction Successfull"), any(LocalDateTime.class));
        assertEquals((String) "Withdrawal", (String) typeCaptor.getValue());
        assertEquals((String) "success", (String) statusCaptor.getValue());
    }
    @Test
    @Tag("invalid")
    public void insufficientFundsReturnsBadRequestAndLogsFailure() {
        int userId = 303;
        int accountId = 77;
        double currentBalance = 50.00;
        double withdrawal = 75.00;
        User user = mockUserWithId(String.valueOf(userId));
        when(session.getAttribute("user")).thenReturn(user);
        when(accountRepository.getAccountBalance(userId, accountId)).thenReturn(currentBalance);
        Map<String, String> requestMap = buildRequest("75.00", "77");
        ResponseEntity response = controller.transfer(requestMap, session);
        assertEquals((HttpStatus) HttpStatus.BAD_REQUEST, (HttpStatus) response.getStatusCode());
        assertEquals((String) "You have insufficient Funds to perform this transfer.", (String) response.getBody());
        verify(accountRepository, never()).changeAccountsBalanceById(anyDouble(), anyInt());
        ArgumentCaptor<Integer> accIdCaptor = ArgumentCaptor.forClass(Integer.class);
        ArgumentCaptor<String> typeCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<Double> amountCaptor = ArgumentCaptor.forClass(Double.class);
        ArgumentCaptor<String> channelCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<String> statusCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<String> messageCaptor = ArgumentCaptor.forClass(String.class);
        ArgumentCaptor<LocalDateTime> timeCaptor = ArgumentCaptor.forClass(LocalDateTime.class);
        verify(transactRepository, times(1)).logTransaction(
                accIdCaptor.capture(),
                typeCaptor.capture(),
                amountCaptor.capture(),
                channelCaptor.capture(),
                statusCaptor.capture(),
                messageCaptor.capture(),
                timeCaptor.capture()
        );
        assertEquals((int) accountId, (int) accIdCaptor.getValue());
        assertEquals((String) "withdrawal", (String) typeCaptor.getValue());
        assertEquals((double) withdrawal, (double) amountCaptor.getValue(), (double) DELTA);
        assertEquals((String) "online", (String) channelCaptor.getValue());
        assertEquals((String) "failed", (String) statusCaptor.getValue());
        assertEquals((String) "Insufficient funds.", (String) messageCaptor.getValue());
        assertDateWithinTolerance(timeCaptor.getValue());
    }
