        },
        {
          "name": "create_at",
          "type": "LocalDateTime"
        },
        {
          "name": "updated_at",
          "type": "LocalDateTime"
        }
      ],
      "validation": {
        "first_name": "Not empty, min 3 chars",
        "last_name": "Not empty, min 3 chars",
        "email": "Valid email address, not empty, valid pattern",
        "password": "Not empty"
      }
    },
